{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Panther Studio",
  "version": "0.1.0",
  "identifier": "com.pantherstudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Panther Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Vocal-focused desktop DAW",
    "longDescription": "Panther Studio is a vocal-focused digital audio workstation for recording, editing, mixing and mastering vocals on Windows.",
    "copyright": "Copyright (c) Panther Studio",
    "publisher": "Panther Studio",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGNEFGRTMxRjI0NERBNjQKUldSazJrVHlNZjVLTHhhai83SHZwVEdxVjJleDNXZ3N6Qno3NnU1OHJmSVo3eHdKM2FUNmVpTTcK",
      "endpoints": [
        "https://github.com/panthercityhelpersfw/panther-studio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
